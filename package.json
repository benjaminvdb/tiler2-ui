{
  "name": "agent-chat-ui",
  "readme": "https://github.com/langchain-ai/agent-chat-ui/blob/main/README.md",
  "homepage": "https://agentchat.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/langchain-ai/agent-chat-ui.git"
  },
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "VITE_APP_VERSION=$(node -p \"require('./package.json').version\") tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:diff": "git diff --name-only --diff-filter=ACMR main...HEAD | grep -E '\\.(ts|tsx)$' | xargs -r eslint --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:diff": "git diff --name-only --diff-filter=ACMR main...HEAD | grep -E '\\.(ts|tsx)$' | xargs -r prettier --check",
    "analyze": "vite-bundle-visualizer",
    "check": "tsc --noEmit",
    "check:watch": "tsc --noEmit --watch",
    "knip": "knip",
    "knip:production": "knip --production",
    "knip:export": "knip --reporter json > knip-report.json",
    "validate": "pnpm run check && pnpm run lint && pnpm run format:check",
    "validate:quick": "pnpm run check && pnpm run lint:diff && pnpm run format:diff",
    "clean": "rm -rf dist node_modules/.vite",
    "clean:full": "rm -rf dist node_modules/.vite node_modules pnpm-lock.yaml && pnpm install"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.103",
    "@auth0/auth0-react": "^2.15.0",
    "@fontsource/comic-mono": "^5.2.5",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.40.0",
    "@tanstack/react-table": "^8.21.3",
    "@truto/turndown-plugin-gfm": "^1.0.2",
    "ai": "^6.0.101",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "katex": "^0.16.33",
    "lucide-react": "^0.575.0",
    "p-retry": "^7.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.2",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "knip": "^5.85.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "overrides": {
    "react-is": "^19.2.4"
  },
  "packageManager": "pnpm@10.24.0"
}
